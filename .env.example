# ============================================================
# points-mall-frontend — Environment Variables Reference
# Copy this file to .env.development / .env.test / .env.production and fill in real values.
# Next.js built-in env loading: https://nextjs.org/docs/app/building-your-application/configuring/environment-variables
#
# NEXT_PUBLIC_* variables are exposed to the browser bundle.
# Variables without NEXT_PUBLIC_ are server-side only.
# NEVER commit .env.local or files with real secrets to Git.
# ============================================================

# ── BFF API (browser-accessible) ────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_APP_ENV=development

# ── Next.js internal (server-side only) ─────────────────────
# Used by Next.js API route handlers to call BFF from server
BFF_INTERNAL_URL=http://localhost:4000
